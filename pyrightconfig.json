{
  "strict": true,
  "pythonVersion": "3.14",
  "targetVersion": "3.14",
  "reportMissingImports": "error",
  "reportMissingModuleSource": "error",
  "reportMissingTypeStubs": "error",
  "reportUnknownMemberType": "error",
  "reportUnknownParameterType": "error",
  "reportUnknownVariableType": "error",
  "reportUnknownArgumentType": "error",
  "reportUnknownLambdaType": "error",
  "reportGeneralTypeIssues": "error",
  "reportIncompatibleMethodOverride": "error",
  "reportIncompatibleVariableOverride": "error",
  "reportInvalidTypeForm": "error",
  "reportInvalidTypeVarUse": "error",
  "reportInvalidTypeComments": "error",
  "reportUnusedTypeIgnore": "error",
  "reportUnusedCast": "error",
  "reportUnnecessaryCast": "error",
  "reportUnnecessaryIsInstance": "error",
  "reportUnnecessaryComparison": "error",
  "reportUnnecessaryTypeIgnoreComment": "error",
  "reportUnusedIgnore": "error",
  "reportUnusedParameter": "warning",
  "reportPrivateImportUsage": "warning",
  "reportDeprecated": "warning",
  "reportConstantRedefinition": "warning",
  "reportInconsistentConstructor": "warning",
  "reportInconsistentOverload": "warning",
  "reportInvalidStubStatement": "warning",
  "reportMissingParameterType": "error",
  "reportMissingTypeArgument": "error",
  "reportWildcardImportFromLibrary": "warning",
  "reportImplicitRelativeImport": "warning",
  "reportUnusedClass": "warning",
  "reportUnusedFunction": "warning",
  "reportUnusedVariable": "warning",
  "reportUnusedCoroutine": "warning",
  "reportUnusedImport": "warning",
  "reportUnusedExcept": "warning",
    "reportUnusedExpression": "warning",
    "exclude": [
    "**/node_modules",
    "**/__pycache__",
    "**/.pytest_cache",
    "**/.ruff_cache",
    "**/build",
    "**/dist",
    "**/*.egg-info",
    "**/.venv",
    "**/venv",
    "**/env",
    "**/tests/**/test_*.py",
    "**/tests/conftest.py",
    "**/examples/**/*.py",
    "**/scripts/**/*.py",
    "**/docs/**/*.py",
    "**/bioplausible/tests/**/*.py"
  ],
  "include": [
    "bioplausible/**/*.py",
    "tests/**/*.py"
  ],
  "typeCheckingMode": "strict",
  "useLibraryCodeForTypes": true,
  "autoImportCompletions": true,
  "analysisExclude": [
    "**/tests/**",
    "**/examples/**",
    "**/scripts/**",
    "**/docs/**",
    "**/bioplausible/tests/**"
  ]
}